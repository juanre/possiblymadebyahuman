# Prod-like local run against external Neon Postgres.
# Copy to .env.localprod and fill DATABASE_URL; do not commit real secrets.
DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/DB?sslmode=require
PMBAH_PORT=8000
PUBLIC_BASE_URL=http://localhost:8000
NODE_ENV=production
LOG_LEVEL=info
IMAGE=possiblymadebyahuman:latest
