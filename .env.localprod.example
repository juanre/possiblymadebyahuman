# Prod-like local run against external Neon Postgres.
# Copy to .env.localprod and fill DATABASE_URL; do not commit real secrets.
DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/DB?sslmode=require
PMBAH_PORT=8000
PUBLIC_BASE_URL=http://localhost:8000
NODE_ENV=production
LOG_LEVEL=info
IMAGE=ghcr.io/OWNER/possiblymadebyahuman:latest

PG_POOL_MAX=5
PG_POOL_IDLE_TIMEOUT_MS=30000
PG_POOL_CONNECTION_TIMEOUT_MS=5000
PG_STATEMENT_TIMEOUT_MS=15000
RECORD_BODY_LIMIT_BYTES=10000000
