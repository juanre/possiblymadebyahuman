{
  "manifest_version": 3,
  "name": "possiblymadebyahuman",
  "version": "__VERSION__",
  "description": "Content-blind writing record. Not a detector.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "possiblymadebyahuman"
  },
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "permissions": ["storage", "clipboardWrite", "alarms"],
  "host_permissions": ["<all_urls>"],
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  }
}
