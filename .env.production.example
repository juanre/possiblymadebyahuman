# Production container environment for Render + Neon.
# Copy values to Render's environment variable UI or to local .env.production.
# Do not commit .env.production or real secrets.

# Required: Neon pooled or direct Postgres connection string with TLS.
DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/DB?sslmode=require

# Render provides PORT automatically for web services. Keep 8000 for Docker/local defaults.
PORT=8000

# Required: public HTTPS origin for generated record URLs.
PUBLIC_BASE_URL=https://possiblymadebyahuman.com
NODE_ENV=production
LOG_LEVEL=info

# GHCR image Render should deploy. Prefer an immutable version tag for production.
IMAGE=ghcr.io/OWNER/possiblymadebyahuman:0.1.0

# Neon/serverless-friendly runtime knobs.
PG_POOL_MAX=5
PG_POOL_IDLE_TIMEOUT_MS=30000
PG_POOL_CONNECTION_TIMEOUT_MS=5000
PG_STATEMENT_TIMEOUT_MS=15000
RECORD_BODY_LIMIT_BYTES=10000000
